# Unclogme Supabase — environment template
# Copy to .env and fill in values. Never commit .env.

# -----------------------------------------------------------------------------
# Supabase (destination)
# -----------------------------------------------------------------------------
SUPABASE_URL=https://wbasvhvvismukaqdnouk.supabase.co
SUPABASE_PROJECT_ID=wbasvhvvismukaqdnouk

# Service role JWT — full DB access. Obtain from:
#   Supabase Dashboard → Project Settings → API → service_role (reveal)
# Rotate via: Dashboard → API → Rotate service_role key.
SUPABASE_SERVICE_ROLE_KEY=

# Personal Access Token — management plane (used for CLI, Edge Function deploys).
# Obtain from: https://supabase.com/dashboard/account/tokens
SUPABASE_PAT=

# -----------------------------------------------------------------------------
# Source systems
# -----------------------------------------------------------------------------

# Jobber — OAuth app credentials. Access/refresh tokens are managed via
# scripts/jobber_auth.js (one-time browser flow) and stored locally.
JOBBER_CLIENT_ID=
JOBBER_CLIENT_SECRET=
JOBBER_ACCESS_TOKEN=
JOBBER_REFRESH_TOKEN=

# Samsara — static API token. Needs "Webhooks write" scope for registration.
SAMSARA_API_TOKEN=

# Airtable — Personal Access Token with read access to Unclogme base.
AIRTABLE_PAT=

# Fillout — API key (sunset May 2026, migration-only).
FILLOUT_API_KEY=

# -----------------------------------------------------------------------------
# Notifications (optional)
# -----------------------------------------------------------------------------
# Slack incoming webhook — used by health-check jobs and incident alerts.
SLACK_WEBHOOK_URL=
